# ============================================================
# PRODUCTION .env — Jeu de Clans
# Copier ce fichier en .env sur le serveur et remplir les valeurs
# ============================================================

APP_NAME="Jeu de Clans"
APP_ENV=production
APP_KEY=                        # php artisan key:generate
APP_DEBUG=false
APP_URL=https://ton-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning               # 'debug' expose trop d'infos en prod

# ── Base de données ───────────────────────────────────────────
# SQLite : ok pour faible charge. MySQL recommandé au-delà de ~50 joueurs simultanés.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jeu_clan
DB_USERNAME=jeu_clan_user
DB_PASSWORD=MOT_DE_PASSE_FORT

# ── Sessions & Cache ──────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=180
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=ton-domaine.com
SESSION_SECURE_COOKIE=true      # HTTPS uniquement

CACHE_STORE=database

# ── Queue ────────────────────────────────────────────────────
QUEUE_CONNECTION=database
# Lancer les workers : php artisan queue:work --daemon

# ── Mail ─────────────────────────────────────────────────────
# Configurer un vrai mailer (Mailgun, SMTP, etc.)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=ton@email.com
MAIL_PASSWORD=MOT_DE_PASSE_MAIL
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@ton-domaine.com"
MAIL_FROM_NAME="Jeu de Clans"

# ── Stockage ─────────────────────────────────────────────────
FILESYSTEM_DISK=local

VITE_APP_NAME="Jeu de Clans"

# ============================================================
# CHECKLIST DÉPLOIEMENT
# ============================================================
# 1. Copier .env.production.example → .env et remplir les valeurs
# 2. php artisan key:generate
# 3. php artisan migrate --force
# 4. php artisan db:seed --force        (soldats + commandants)
# 5. npm run build
# 6. php artisan optimize               (cache config/routes/views)
# 7. php artisan storage:link           (si stockage public)
# 8. Ajouter au crontab du serveur :
#    * * * * * cd /chemin/projet && php artisan schedule:run >> /dev/null 2>&1
# 9. (Optionnel) Démarrer un worker queue :
#    php artisan queue:work --daemon
# 10. php artisan make:admin TON_USERNAME
# ============================================================
